      }
    },
    {
      "cell_type": "code",
      "source": [
        "def divide(num1, num2):\n",
        "    if num2 == 0:\n",
        "        return None\n",
        "    else:\n",
        "        return num1 / num2\n",
        "\n",
        "# Run the function and handle the result\n",
        "result = divide(10, 0)\n",
        "if result is None:\n",
        "    print(\"Cannot divide by zero!\")\n",
        "else:\n",
        "    print(f\"Result: {result}\")"
      ],
