# Copy this file to .env and fill in your own key. .env is gitignored --
# never commit real API keys.

# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional: override the model used for parsing quick-add tasks.
# OPENAI_MODEL=gpt-4o-mini

# Get a key at https://aistudio.google.com/apikey -- only needed if you (or
# your users) prefer Gemini over OpenAI for AI quick-add.
GEMINI_API_KEY=AIza-your-key-here

# Optional: override the model used for parsing quick-add tasks via Gemini.
# GEMINI_MODEL=gemini-3.5-flash

# Local model (no key needed) -- selecting "Local model" as your preferred
# provider in Settings runs quick-add parsing on this machine via
# llama-cpp-python instead of calling OpenAI or Gemini. By default it
# downloads a small (~2GB) model from Hugging Face the first time it's used
# and caches it. Override the default model:
# LOCAL_MODEL_REPO=lmstudio-community/Qwen2.5-3B-Instruct-GGUF
# LOCAL_MODEL_FILE=*Q4_K_M.gguf
# Or skip the download entirely and point at a .gguf file already on disk:
# LOCAL_MODEL_PATH=/path/to/your-model.gguf

# Optional: Django's session/cookie-signing secret. Without this, the app
# falls back to a local-dev-only key baked into settings.py. Generate a real
# one before deploying anywhere, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# DJANGO_SECRET_KEY=

# Optional: send real password-reset emails instead of printing them to the
# console (the default). Example for Gmail with an App Password:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# DEFAULT_FROM_EMAIL=you@gmail.com

# Optional: enables the "Sign in with Google" button on the login/register
# pages. Without these, that button is hidden and password login/register
# still works as before. See README.md ("Google sign-in setup") for
# step-by-step instructions on creating these in Google Cloud Console.
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
